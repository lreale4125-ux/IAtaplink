# ═══════════════════════════════════════════
# IAtaplink — NFC Smart Keychains
# Copia in .env e compila i valori
# ═══════════════════════════════════════════

# ── LLM (Google Gemini) ──
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── Telegram ──
# Bot: crea con @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Chat ID: manda /start al bot, poi visita
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Ricerca Web (Serper.dev) ──
# https://serper.dev/
SERPER_API_KEY=your_serper_api_key_here

# ── Email SMTP ──
# Gmail: smtp.gmail.com:587 + App Password
#   (Account Google → Sicurezza → Verifica 2 passaggi → Password per le app)
# Outlook: smtp-mail.outlook.com:587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_SENDER_NAME=IAtaplink — NFC Smart Keychains
