# ═══════════════════════════════════════════
# NFC Smart Keychains — Variabili d'ambiente
# Copia questo file in .env e compila i valori
# ═══════════════════════════════════════════

# ── LLM (OpenAI) ──
# Ottieni la chiave su https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── Telegram ──
# Crea il bot su @BotFather → ottieni il token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Manda /start al bot, poi visita:
# https://api.telegram.org/bot<TOKEN>/getUpdates
# per trovare il tuo chat_id
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Ricerca Web (Serper.dev) ──
# Registrati su https://serper.dev/ e ottieni la chiave
SERPER_API_KEY=your_serper_api_key_here
